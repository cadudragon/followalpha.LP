<?xml version="1.0" encoding="utf-8"?>
<!-- Repo-local feed scope: nuget.org only. Clears any machine/user-global sources (e.g. private
     Azure DevOps feeds) so local restore is reproducible and matches CI. All packages are public. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
