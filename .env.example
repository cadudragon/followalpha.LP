# FollowAlpha.LP — environment variable names (ARCHITECTURE.md §9).
# Copy to `.env` and fill in real values. NEVER commit a filled-in .env (it is gitignored).
# Values here are placeholders only — no secrets in the repo.

# The Graph decentralized gateway API key (Infrastructure — TheGraph adapter).
GRAPH_API_KEY=

# Arbitrum One RPC endpoint (Infrastructure — event reader).
RPC_URL_ARBITRUM=

# Base RPC endpoint (Infrastructure — event reader).
RPC_URL_BASE=

# Alchemy API key (Infrastructure — preferred over raw RPC_URL_* when set; TECH-STACK.md §5).
# When set and an RPC_URL_<CHAIN> is empty, the Collector builds the Alchemy URL for that chain.
ALCHEMY_API_KEY=

# SQLite database file path (Infrastructure). Default: ./data/followalpha-lp.db
LP_DB_PATH=./data/followalpha-lp.db

# Single API key for the Api host auth seam.
LP_API_KEY=
